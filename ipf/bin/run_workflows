#!/bin/bash

INSTALL_DIR=___INSTALL_DIR___
PYTHON="$INSTALL_DIR"/.venv/bin/python
PYTHONPATH=$(readlink -e "$INSTALL_DIR"/..)
WORKFLOW_BASE="$INSTALL_DIR"/etc/ipf/workflow
WORKFLOWS_CONF="$INSTALL_DIR"/etc/workflows.conf

export PYTHONPATH

grep '^/' "$WORKFLOWS_CONF" \
| while read ; do
  fn_workflow=$(echo $REPLY | sed -e "s?$WORKFLOW_BASE/??")
  $PYTHON "$INSTALL_DIR"/run_workflow.py -d "$fn_workflow"
done
